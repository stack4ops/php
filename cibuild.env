# =============================================================================
# cibuild.env — PHP-FPM Image (Nix build)
# =============================================================================

# BUILD
CIBUILD_BUILD_CLIENT=nix

# Flake attribute — maps to packages.<system>.php-83-fpm-<arch>
# cibuild substitutes <arch> automatically based on the runner architecture
CIBUILD_NIX_FLAKE_ATTR=php-83-fpm-amd64

# Attic binary cache (local, from the cibuild lab)
# Significantly speeds up builds — Nix fetches cached derivations
# instead of recompiling everything from scratch
CIBUILD_NIX_CACHE_URL=https://attic.example.com/cibuilder
# CIBUILD_NIX_CACHE_TOKEN=...   # set as a secret in CI

# Always build native (one runner per arch)
CIBUILD_BUILD_NATIVE=1

# TEST
CIBUILD_TEST_ENABLED=1
CIBUILD_TEST_BACKEND=docker

# CHECK
CIBUILD_CHECK_ENABLED=0
