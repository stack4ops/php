# =============================================================================
# cibuild.env — PHP-FPM Image (Nix build)
# =============================================================================

# BUILD
CIBUILD_BUILD_CLIENT=nix
CIBUILD_NIX_FLAKE_VARIANT=fpm
CIBUILD_BUILD_NATIVE=1

# TEST
CIBUILD_TEST_ENABLED=0

# CHECK
CIBUILD_CHECK_ENABLED=0
